--- 
import '../styles/global.css';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait.jpg';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Jimmy P. Le — Building NLP systems for explainable biomedical question answering. PhD researcher at Virginia Commonwealth University, advised by Dr. Bridget McInnes." } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          const theme = stored ?? (prefersLight ? 'light' : 'dark');
          if (theme == 'light') {
            document.documentElement.classList.add('light');
          }
        } catch (e) {
          /* localStorage blocked (private browsing) - fall back to dark default */ 
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e1411" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4efe8" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`https://jimmyphuocle.com${Astro.url.pathname}`} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://jimmyphuocle.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://jimmyphuocle.com/og-image.png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://jimmyphuocle.com/og-image.png" />

    <title>{title}</title>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <nav class="site-nav">
          <a href="/" class="site-brand">Jimmy P. Le</a>
          <div class="site-nav-links">
            <a href="/projects">Projects</a>
            <a href="/publications">Research</a>
            <a href="/about">About</a>
          </div>
        </nav>
      </header>

      <aside class="site-identity">
        <Image
          src={portrait}
          alt="Jimmy P. Le"
          class="identity-portrait"
          width={384}
          height={384}
        />
        <h2 class="identity-name">Jimmy P. Le</h2>
        <p class="identity-title">PhD Student, Computer Science</p>
        <p class="identity-affiliation">
          <a href="https://nlp.cs.vcu.edu">NLP Lab</a><br />
          Virginia Commonwealth University
        </p>
        <p class="identity-advisor">
          Advised by<br />
          Dr. Bridget T. McInnes
        </p>
        <p class="identity-location">Richmond, VA USA</p>
        <ul class="identity-links">
          <li><a href="https://github.com/jimmyphuocle">GitHub</a></li>
          <li><a href="https://scholar.google.com">Google Scholar</a></li>
          <li><a href="https://www.linkedin.com/in/jimmy-le-vcu/">LinkedIn</a></li>
          <li><a href="mailto:lejp3@vcu.edu">Email</a></li>
        </ul>
        <button
          id="theme-toggle"
          type="button"
          class:list="theme-toggle"
          aria-label="Toggle color theme"
        >
          <span class="theme-toggle-icon theme-toggle-icon--dark" aria-hidden="true">☾</span>
          <span class="theme-toggle-icon theme-toggle-icon--light" aria-hidden="true">☀</span>
          <span class="theme-toggle-label">Theme</span>
        </button>
      </aside>

      <main class="site-main">
        <slot />
      </main>

      <aside class="site-aside">
        <slot name="aside" />
      </aside>

      <footer class="site-footer">
        <p>
          <a href="https://github.com/jimmyphuocle">GitHub</a>
          <span class="sep">·</span>
          <a href="https://scholar.google.com">Google Scholar</a>
          <span class="sep">·</span>
          <a href="mailto:lejp3@vcu.edu">Email</a>
        </p>
      </footer>
    </div>
    <script is:inline>
      (function () {
        const button = document.getElementById('theme-toggle');
        if (!button) return;
        button.addEventListener('click', () => {
          const root = document.documentElement;
          const isLight = root.classList.toggle('light');
          try {
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
          } catch (e) {
            /* localStorage blocked; in-session toggle still works */
          }
        });
      })();
    </script>
  </body>
</html>
