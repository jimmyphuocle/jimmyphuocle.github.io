---
import type { CollectionEntry } from 'astro:content';
import StatusPill from './StatusPill.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  showTech?: boolean;
  showCollaborators?: boolean;
  showGithub?: boolean;
  showDescription?: boolean;
}

const {
  project,
  showTech = false,
  showCollaborators = false,
  showGithub = false,
  showDescription = true,
} = Astro.props;
---
<li>
  <h3>
    <a href={`/projects/${project.id}`}>{project.data.title}</a>
  </h3>

  <p class="card-meta">
    <StatusPill status={project.data.status} />
  </p>

  {showDescription && <p>{project.data.description}</p>}

  {showTech && project.data.tech && (
    <p class="card-tech">
      <span class="card-tech-label">Tech</span>
      <span class="card-tech-list">{project.data.tech.join(', ')}</span>
    </p>
  )}

  {showCollaborators && project.data.collaborators && (
    <p><small>With: {project.data.collaborators.join(', ')}</small></p>
  )}

  {showGithub && project.data.github && (
    <p><a href={project.data.github}>GitHub →</a></p>
  )}
</li>
