---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import StatusPill from '../components/StatusPill.astro';

const allProjects = await getCollection('projects');
const allPublications = await getCollection('publications');

const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPublications = allPublications
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Jimmy P. Le">
  <section>
    <h1>Jimmy P. Le</h1>
    <p>
      I'm <span class="emphasis">Jimmy P. Le</span>. I'm a PhD student in
      Computer Science at Virginia Commonwealth University, where I work
      in the Natural Language Processing Lab under Dr. Bridget McInnes.
      My current research focuses on triple filtration in GraphRAG for
      explainable biomedical question answering, integrating
      Literature-Based Discovery strategies into retrieval pipelines
      over UMLS-derived knowledge graphs.
    </p>
    <p>
      Outside of research, I work as a Network Operations Center analyst
      at VCU Infrastructure Services. Before VCU, I held an IT Team Lead
      role at Wichita State University.
    </p>
    <p>
      I'm currently exploring software, ML, and NLP engineering roles &mdash;
      ideally in or near the DC / Northern Virginia area. If you're
      hiring or want to talk about biomedical NLP, GraphRAG, or
      retrieval failure modes, I'd love to hear from you.
    </p>

    <h2>Currently</h2>
    <ul>
      <li>Running ablation experiments on the LBD-GraphRAG project across multiple retrieval conditions</li>
      <li>Building a Biomedical NLP API portfolio project with FastAPI and Hugging Face Transformers</li>
      <li>Working through NeetCode 150 for technical interviews</li>
    </ul>
  </section>

  <section>
    <h2>Featured Projects</h2>
    {featuredProjects.length === 0 && <p>No featured projects yet.</p>}
    <ul>
      {featuredProjects.map((project) => (
        <ProjectCard
          project={project}
          showTech={true}
        />
      ))}
    </ul>
    <p><a href="/projects">All projects &rarr;</a></p>
  </section>

  <section>
    <h2>Featured Publications</h2>
    {featuredPublications.length === 0 && (
      <p>No featured publications yet.</p>
    )}
    <ul>
      {featuredPublications.map((pub) => (
        <PublicationCard pub={pub} variant="compact" showYear={true} />
      ))}
    </ul>
    <p><a href="/publications">All publications &rarr;</a></p>
  </section>
</BaseLayout>

