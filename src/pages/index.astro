---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');
const allPublications = await getCollection('publications');

const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPublications = allPublications
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Jimmy P. Le">
  <aside slot="aside" class="currently">
    <h2 class="currently-label">Currently</h2>
    <ul class="currently-list">
      <li>
        Writing up <strong>LBD-GraphRAG</strong> — a knowledge-graph
        retrieval system for explainable biomedical question answering.
        First dissertation paper, <a href="https://nlp.cs.vcu.edu">VCU NLP Lab</a>.
      </li>
    </ul>
    <p class="currently-updated">Updated April 2026</p>
  </aside>

  <section>
    <h1>Jimmy P. Le</h1>
    <p>
      I build NLP systems and am finishing a PhD on explainable
      biomedical question answering at Virginia Commonwealth University.
    </p>
  </section>

  <section>
    <h2>Featured Projects</h2>
    {featuredProjects.length === 0 && <p>No featured projects yet.</p>}
    <ul>
      {featuredProjects.map((project) => (
        <li>
          <h3>
            <a href={`/projects/${project.id}`}>{project.data.title}</a>
          </h3>
          <p><em>Status: {project.data.status}</em></p>
          <p>{project.data.description}</p>
          {project.data.tech && (
            <p><small>Tech: {project.data.tech.join(', ')}</small></p>
          )}
        </li>
      ))}
    </ul>
    <p><a href="/projects">All projects →</a></p>
  </section>

  <section>
    <h2>Featured Publications</h2>
    {featuredPublications.length === 0 && (
      <p>No featured publications yet.</p>
    )}
    <ul>
      {featuredPublications.map((pub) => (
        <li>
          <h3>{pub.data.title}</h3>
          <p>{pub.data.authors.join(', ')}</p>
          <p>
            <em>
              {pub.data.venue_short ?? pub.data.venue} · {pub.data.year}
              {pub.data.status === 'in_preparation' && ' · In preparation'}
              {pub.data.status === 'under_review' && ' · Under review'}
            </em>
          </p>
        </li>
      ))}
    </ul>
    <p><a href="/publications">All publications →</a></p>
  </section>
</BaseLayout>
