---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusPill from '../../components/StatusPill.astro';

export async function getStaticPaths() {
  const publications = await getCollection('publications');
  return publications.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'publications'>;
};

const { entry } = Astro.props;

// Build the links row from whichever optional URLs exist
type DetailLink = { href: string; label: string };
const links: DetailLink[] = [];
if (entry.data.pdf)   links.push({ href: entry.data.pdf, label: 'PDF' });
if (entry.data.arxiv) links.push({ href: `https://arxiv.org/abs/${entry.data.arxiv}`, label: 'arXiv' });
if (entry.data.doi)   links.push({ href: `https://doi.org/${entry.data.doi}`, label: 'DOI' });
if (entry.data.code)  links.push({ href: entry.data.code, label: 'Code' });
---
<BaseLayout title={`${entry.data.title} — Jimmy P. Le`}>
  <article>
    <header>
      <p><a href="/publications">← All publications</a></p>

      <h1>{entry.data.title}</h1>

      <p class="card-meta">
        <StatusPill status={entry.data.status} />
      </p>
    </header>

    <dl class="spec-table">
      <div class="spec-row">
        <dt class="spec-label">Authors</dt>
        <dd class="spec-value">{entry.data.authors.join(', ')}</dd>
      </div>

      <div class="spec-row">
        <dt class="spec-label">Venue</dt>
        <dd class="spec-value">{entry.data.venue} · {entry.data.year}</dd>
      </div>

      {links.length > 0 && (
        <div class="spec-row">
          <dt class="spec-label">Links</dt>
          <dd class="spec-value">
            {links.map((link, i) => (
              <Fragment>
                {i > 0 && ' · '}
                <a href={link.href}>{link.label}</a>
              </Fragment>
            ))}
          </dd>
        </div>
      )}
    </dl>

    {entry.data.abstract && (
      <section>
        <h2>Abstract</h2>
        <p>{entry.data.abstract}</p>
      </section>
    )}

    {entry.data.bibtex && (
      <section>
        <h2>BibTeX</h2>
        <pre><code>{entry.data.bibtex}</code></pre>
      </section>
    )}
  </article>
</BaseLayout>
