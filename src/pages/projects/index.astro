---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import StatusPill from '../../components/StatusPill.astro';

const allProjects = await getCollection('projects');

// Sort by date, newest first
const sortedProjects = allProjects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Group by status
const activeProjects = sortedProjects.filter((p) => p.data.status === 'active');
const completedProjects = sortedProjects.filter((p) => p.data.status === 'completed');
const archivedProjects = sortedProjects.filter((p) => p.data.status === 'archived');
---

<BaseLayout title="Projects — Jimmy P. Le">
  <div slot="aside" class="aside-block">
    <h2 class="aside-label">Status</h2>
    <ul class="aside-legend">
      <li>
        <StatusPill status="active" />
        <a href="#active">Active</a>
      </li>
      <li>
        <StatusPill status="completed" />
        <a href="#completed">Completed</a>
      </li>
      <li>
        <StatusPill status="archived" />
        <a href="#archived">Archived</a>
      </li>
    </ul>
  </div>

  <section>
    <h1>Projects</h1>
    <p>
      Things I'm building and have built. Most are at the intersection of
      NLP, biomedical informatics, and ML systems engineering.
    </p>
  </section>

  {activeProjects.length > 0 && (
    <section id="active">
      <h2>Active</h2>
      <ul>
        {activeProjects.map((project) => (
          <ProjectCard
            project={project}
            showTech={true}
            showCollaborators={true}
            showGithub={true}
          />
        ))}
      </ul>
    </section>
  )}

  {completedProjects.length > 0 && (
    <section id="completed">
      <h2>Completed</h2>
      <ul>
        {completedProjects.map((project) => (
          <ProjectCard
            project={project}
            showTech={true}
          />
       ))}
      </ul>
    </section>
  )}

  {archivedProjects.length > 0 && (
    <section id="archived">
      <h2>Archived</h2>
      <ul>
        {archivedProjects.map((project) => (
          <li>
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {sortedProjects.length === 0 && (
    <p><em>No projects yet. Check back soon.</em></p>
  )}
</BaseLayout>
